{
  "name": "lingua-priority",
  "version": "0.1.0",
  "description": "Sensible language ordering for dropdowns. Stop scrolling past Somali to find Spanish.",
  "author": "SPANISH FLU <mrflu1918@proton.me>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.15",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^4.0.15"
  },
  "keywords": [
    "language",
    "languages",
    "dropdown",
    "select",
    "i18n",
    "internationalization",
    "locale",
    "iso-639"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/spanishflu-est1918/lingua-priority"
  },
  "sideEffects": false
}
